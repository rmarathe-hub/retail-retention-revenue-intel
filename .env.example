# PostgreSQL connection for Docker-based local development
# Copy to .env: cp .env.example .env
#
# Host port 5433 is intentional — avoids conflicts with other local Postgres on 5432.
# Inside Docker, Postgres listens on container port 5432; connect from Mac via localhost:5433.

POSTGRES_HOST=localhost
POSTGRES_PORT=5433
POSTGRES_DB=retail_analytics
POSTGRES_USER=retail_user
POSTGRES_PASSWORD=retail_pass

DATABASE_URL=postgresql://retail_user:retail_pass@localhost:5433/retail_analytics
